
          <div id="examples">

            <p>
              The example pages show the effects of some common configuration options.
            </p>

           <table class="table table-striped" aria-labelledby="id-title">
            <thead>
              <th>Example</th>
              <th>Description</th>
            </thead>
            <tbody>
            {% for sp in subPages %}
              <tr>
                <td><a href="{{sp.filename}}">{{sp.title | safe}}</a></td>
                <td>{{ sp.description}}</td>
              </tr>
            {% endfor %}
            </tbody>
           </table>

        </div>

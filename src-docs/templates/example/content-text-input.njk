    <script>
      function updateOutput() {
        const outputElem = document.querySelector('#id-output');
        const rangeElem = document.querySelector('#id-range');
        outputElem.textContent = rangeElem.value;
      }
      const rangeElem = document.querySelector('#id-range');
      rangeElem.addEventListener('change', updateOutput);
      updateOutput();

    </script>


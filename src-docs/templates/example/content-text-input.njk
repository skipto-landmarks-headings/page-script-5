              <p>NOTE: The shortcut key is disabled when focus is on a text input control.</p>

              <form>
                <div class="control" id="id-form">
                  <label for="id-name">Name</label>
                  <input id="id-name" type="text" size="25">
                </div>


                <div class="control">
                  <label for="id-range">Number</label>
                  <input id="id-range" type="range" value="50">
                  <output id="id-output" form="id-form" for="id-range"></output>
                </div>

                <div class="control">
                  <input id="id-checkbox" type="checkbox" name="rg"/>
                  <label for="id-checkbox" style="display: inline-block">Enable items</label>
                </div>
                <fieldset>
                  <legend>Items</legend>
                  <div class="control">
                    <input id="id-radio-a" type="radio" name="rg"/>
                    <label for="id-radio-a">Item A</label>
                  </div>
                  <div class="control">
                    <input id="id-radio-b" type="radio" name="rg"/>
                    <label for="id-radio-b">Item B</label>
                  </div>
                  <div class="control">
                    <input id="id-radio-c" type="radio" name="rg"/>
                    <label for="id-radio-c">Item C</label>
                  </div>
                  <div class="control">
                    <input id="id-radio-d" type="radio" name="rg"/>
                    <label for="id-radio-d">Item D</label>
                  </div>
                </fieldset>

                <div class="control">
                  <label for="id-optons">Options</label>
                  <select id="id-options">
                    <option>Option A</option>
                    <option>Option B</option>
                    <option>Option C</option>
                    <option>Option D</option>
                  </select>
                </div>

                <div class="control">
                  <label for="id-coment">Comment</label>
                  <textarea id="id-comment" rows="4" cols="20">enter comment here</textarea>
                </div>

                <div class="control">
                  <button>Button 1</button>
                  <input type="button" value="Button 2"/>
                <div class="control">

                <div class="control">
                  <input type="submit"/>
                  <input type="reset"/>
                </div>
              </form>

